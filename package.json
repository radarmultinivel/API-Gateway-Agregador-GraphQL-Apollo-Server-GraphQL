{
  "name": "api-gateway-bff-graphql",
  "version": "1.0.0",
  "description": "API Gateway BFF com Apollo Server GraphQL para agregação de dados de múltiplos sistemas REST",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
